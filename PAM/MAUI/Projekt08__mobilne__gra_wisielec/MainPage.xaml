<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Projekt08__mobilne__gra_wisielec.MainPage">
    <VerticalStackLayout Padding="20" Loaded="VerticalStackLayout_Loaded">
        <Label x:Name="erro" FontSize="20" Text="Errors: 0 of 6" HorizontalOptions="Center" VerticalOptions="Center" />
        <HorizontalStackLayout x:Name="word" Margin="0" Padding="0" HeightRequest="70" HorizontalOptions="Start" VerticalOptions="Center"></HorizontalStackLayout>
        <Button x:Name="resetBtn" Text="Reset" Clicked="resetBtn_Clicked"/>
        <FlexLayout Margin="6" Padding="20" x:Name="keyboard" Wrap="Wrap"></FlexLayout>
    </VerticalStackLayout>
</ContentPage>
