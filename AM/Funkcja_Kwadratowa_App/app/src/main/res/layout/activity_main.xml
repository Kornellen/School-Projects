<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/material_dynamic_neutral40"
    >
    <TextView
        android:textColor="@color/cardview_light_background"
        android:id="@+id/app_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:textSize="30sp"
        android:textAlignment="center"
        />
    <TextView
        android:id="@+id/a_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Podaj A:"
        android:textColor="@color/cardview_light_background"
        android:textAlignment="center"
        android:textSize="25sp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/app_header"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <EditText
        android:id="@+id/a_input"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:textColor="@color/cardview_light_background"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/a_header"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <TextView
        android:id="@+id/b_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Podaj B:"
        android:textColor="@color/cardview_light_background"
        android:textAlignment="center"
        android:textSize="25sp"
        app:layout_constraintTop_toBottomOf="@id/a_input"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <EditText
        android:id="@+id/b_input"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:textColor="@color/cardview_light_background"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/b_header"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <TextView
        android:id="@+id/c_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Podaj C:"
        android:textColor="@color/cardview_light_background"
        android:textAlignment="center"
        android:textSize="25sp"
        app:layout_constraintTop_toBottomOf="@id/b_input"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <EditText
        android:id="@+id/c_input"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:textColor="@color/cardview_light_background"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/c_header"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <TextView
        android:id="@+id/func_lbl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="f(x) = ax² + bx + c"
        android:textSize="20sp"
        android:textColor="@color/cardview_light_background"
        app:layout_constraintTop_toBottomOf="@id/c_input"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="10dp"
        />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/results_lo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/func_lbl"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="20dp">
        <TextView
            android:id="@+id/delta_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Δ = ?"
            android:textColor="@color/cardview_light_background"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/result_lbl"
            />
        <TextView
            android:id="@+id/result_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="x ∊ ∅"
            android:textColor="@color/cardview_light_background"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/delta_lbl"
            app:layout_constraintRight_toRightOf="parent"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <Button
        android:id="@+id/calc_btn"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:textColor="@color/white"
        android:text="OBLICZ"
        app:cornerRadius="10dp"
        android:backgroundTint="@color/cardview_shadow_start_color"
        app:layout_constraintTop_toBottomOf="@id/results_lo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="15dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>
