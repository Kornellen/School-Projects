<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/gray">
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kantor Walutowy"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:textColor="@color/lighterWhite"
            android:textSize="40sp"
            />

        <ImageView
            android:id="@+id/appImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/money"
            app:layout_constraintTop_toBottomOf="@id/appTitle"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            />

        <TextView
            android:id="@+id/userInputTitle"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="44dp"
            android:text="Podaj kwotę (zł)"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appImage"
            android:textColor="@color/lighterWhite"
            android:textSize="25sp"/>

        <EditText
            android:id="@+id/userInput"
            android:layout_width="250dp"
            android:layout_height="40dp"
            android:layout_marginTop="52dp"
            android:inputType="numberDecimal"
            app:layout_constraintHorizontal_bias="0.503"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userInputTitle"
            android:textColor="@color/lighterWhite"
            android:backgroundTint="@color/lighterWhite"
            />

        <TextView
            android:id="@+id/currencyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Wybierz walutę"
            android:textColor="@color/lighterWhite"
            android:textSize="25sp"
            app:layout_constraintHorizontal_bias="0.509"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userInput" />

        <Spinner
            android:id="@+id/currencySpr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintHorizontal_bias="0.529"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currencyTitle"
            android:backgroundTint="@color/lighterWhite"
            android:background="@color/gray"
            />
        <Button
            android:id="@+id/convertBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:text="PRZELICZ"
            app:cornerRadius="0dp"
            android:backgroundTint="#FF525252"
            app:layout_constraintHorizontal_bias="0.538"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currencySpr" />

        <EditText
            android:id="@+id/resultET"
            android:layout_width="250dp"
            android:layout_height="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.503"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/convertBtn"
            app:layout_constraintVertical_bias="0.28"
            android:textColor="@color/lighterWhite"
            android:backgroundTint="@color/lighterWhite"/>



</androidx.constraintlayout.widget.ConstraintLayout>