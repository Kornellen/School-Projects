<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/app_logo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_margin="10dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@drawable/ic_launcher_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <TextView
        android:id="@+id/app_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/app_logo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="10dp"
        android:text="@string/app_name"
        android:textSize="40sp"
        />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        app:layout_constraintTop_toBottomOf="@id/app_name"
        android:background="#353535"
        android:layout_marginTop="10dp"
        />

    <ScrollView
        android:id="@+id/activities_scroll"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="20dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp">
                <ImageButton
                    android:id="@+id/imgBtn1"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/images"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
                <ImageButton
                    android:id="@+id/imgBtn2"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/unnamed"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
                <ImageButton
                    android:id="@+id/imgBtn3"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/dsc_0035_0"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                >
                <ImageButton
                    android:id="@+id/imgBtn4"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/education_pictures_jwpwcxstcv9mbn6y"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
                <ImageButton
                    android:id="@+id/imgBtn5"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/pobrane"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
                <ImageButton
                    android:id="@+id/imgBtn6"
                    android:adjustViewBounds="true"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@color/black"
                    android:src="@drawable/fc27fb81e77cc56ba4ed981d7801ceb9"
                    android:scaleType="fitXY"
                    android:layout_margin="10dp"
                    />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintTop_toBottomOf="@id/activities_scroll"
        android:orientation="horizontal">
        <TextView
            android:layout_width="135dp"
            android:layout_height="match_parent" />
        <TextView
            android:layout_width="135dp"
            android:layout_height="match_parent" />
        <TextView
            android:layout_width="135dp"
            android:layout_height="match_parent" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>